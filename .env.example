# Database (PostgreSQL via Docker)
DATABASE_URL=postgresql://user:password@localhost:5433/paladin
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=user
DATABASE_PW=password
DATABASE_NAME=paladin

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Resend (email service) - required for org approval/rejection emails
RESEND_API_KEY=

# Push Notifications (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Notification email 
# (For local testing of Resend emails, which would normally go to Stephen)
NOTIFICATION_EMAIL=

# PayPal subscriptions (client: SDK; server: verify subscription with PayPal API)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_PLAN_ID=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# Sandbox default in code; use https://api-m.paypal.com for live
PAYPAL_API_BASE=
